@page "/"
@page "/torrents"
@using System.Globalization
@using TransmissionManager.Api.Common.Dto.Torrents
@using TransmissionManager.Api.Common.Dto.Transmission
@using TransmissionManager.Web.Components
@using TransmissionManager.Web.Constants
@using TransmissionManager.Web.Services
@inherits CommonComponentBase
@inject TransmissionManagerClient Client

<PageTitle>Home - Transmission Manager</PageTitle>

@if (_showNoTorrentsMessage)
{
    <p>@Message</p>
    @if (!string.IsNullOrEmpty(_suggestedAddress))
    {
        <a href="@_suggestedAddress">@_suggestedAction</a>
    }
}
else
{
    <Virtualize TItem="TorrentDto" ItemsProvider="LoadTorrentsProvider" Context="torrent">
        <ItemContent>
            <TorrentCard @key="torrent.Id" Torrent="torrent" RefreshAsync="RefreshTorrentAsync" DeleteAsync="DeleteTorrentAsync" />
        </ItemContent>
    </Virtualize>
}

@code
{
    private bool _showNoTorrentsMessage;
    private List<TorrentDto> _loadedTorrents = new();
    private int _totalTorrentsCount;

    private string _suggestedAddress = string.Empty;
    private string _suggestedAction = string.Empty;

    private protected override string BusyMessage => "Loading torrents...";

    protected override async Task OnInitializedAsync()
    {
        // Check if there are any torrents to determine if we should show the no torrents message
        var initialPage = await CallService(
            Client,
            static client => client.GetTorrentPageAsync(new()
            {
                Take = 1,
                OrderBy = GetTorrentPageOrder.RefreshDateDesc
            }));

        if (initialPage is null)
        {
            _showNoTorrentsMessage = true;
            _suggestedAddress = PageAddresses.Connect;
            _suggestedAction = "Connect to Transmission Manager";
        }
        else if (initialPage.Torrents.Count is 0)
        {
            _showNoTorrentsMessage = true;
            Message = "No torrents found.";
            _suggestedAddress = PageAddresses.TorrentsAdd;
            _suggestedAction = "Add a torrent";
        }
        else
        {
            _showNoTorrentsMessage = false;
            Message = string.Empty;
        }
    }

    private async ValueTask<ItemsProviderResult<TorrentDto>> LoadTorrentsProvider(ItemsProviderRequest request)
    {
        if (IsBusy)
            return new ItemsProviderResult<TorrentDto>([], 0);

        try
        {
            var startIndex = request.StartIndex;
            var count = request.Count;

            // For keyset pagination, we need to determine the anchor point
            long? anchorId = null;
            string? anchorValue = null;

            // If we have cached torrents and the request is for a range we can satisfy, use cache
            if (startIndex < _loadedTorrents.Count)
            {
                var cachedItems = _loadedTorrents
                    .Skip(startIndex)
                    .Take(count)
                    .ToList();
                
                // If we can fully satisfy the request from cache, do so
                if (cachedItems.Count == count || 
                    (startIndex + cachedItems.Count >= _totalTorrentsCount && _totalTorrentsCount > 0))
                {
                    return new ItemsProviderResult<TorrentDto>(cachedItems, _totalTorrentsCount);
                }
            }

            // Need to fetch more data - determine anchor from last loaded torrent
            if (_loadedTorrents.Count > 0)
            {
                var lastTorrent = _loadedTorrents[^1];
                anchorId = lastTorrent.Id;
                anchorValue = lastTorrent.RefreshDate.ToUniversalTime()
                    .ToString("yyyyMMddHHmmssfffffffZ", CultureInfo.InvariantCulture);
            }

            var torrentPage = await CallService(
                Client,
                client => client.GetTorrentPageAsync(new()
                {
                    Take = count,
                    OrderBy = GetTorrentPageOrder.RefreshDateDesc,
                    AnchorId = anchorId,
                    AnchorValue = anchorValue,
                    Direction = GetTorrentPageDirection.Forward
                }));

            if (torrentPage is not null)
            {
                var torrents = torrentPage.Torrents.ToList();
                
                // Add newly fetched torrents to cache
                foreach (var torrent in torrents)
                {
                    if (!_loadedTorrents.Any(t => t.Id == torrent.Id))
                    {
                        _loadedTorrents.Add(torrent);
                    }
                }

                // Update total count estimate
                _totalTorrentsCount = string.IsNullOrEmpty(torrentPage.NextPageAddress)
                    ? _loadedTorrents.Count
                    : _loadedTorrents.Count + 1000; // Estimate more items if there's a next page

                // Return the requested range from our cache
                var result = _loadedTorrents
                    .Skip(startIndex)
                    .Take(count)
                    .ToList();

                return new ItemsProviderResult<TorrentDto>(result, _totalTorrentsCount);
            }
            else
            {
                _showNoTorrentsMessage = true;
                _suggestedAddress = PageAddresses.Connect;
                _suggestedAction = "Connect to Transmission Manager";
                return new ItemsProviderResult<TorrentDto>([], 0);
            }
        }
        catch
        {
            return new ItemsProviderResult<TorrentDto>([], 0);
        }
    }

    private async Task RefreshTorrentAsync(long id)
    {
        var response = await Client.RefreshTorrentByIdAsync(id);
        if (response.TransmissionResult is TransmissionAddResult.Added)
        {
            // Clear loaded torrents to force reload
            _loadedTorrents.Clear();
            _showNoTorrentsMessage = false;
            StateHasChanged();
        }
    }

    private async Task DeleteTorrentAsync(long id, DeleteTorrentByIdType deleteType)
    {
        await Client.DeleteTorrentByIdAsync(id, deleteType);
        // Clear loaded torrents to force reload
        _loadedTorrents.Clear();
        _showNoTorrentsMessage = false;
        StateHasChanged();
    }
}
